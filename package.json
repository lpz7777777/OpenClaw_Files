{
  "name": "openclaw-file-manager",
  "version": "1.0.1",
  "description": "基于 OpenClaw 的桌面文件整理工作区",
  "main": "main.js",
  "productName": "OpenClaw Files",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:backend": "powershell -ExecutionPolicy Bypass -File ./scripts/build-backend.ps1",
    "build:win": "npm run build:backend && electron-builder --win nsis"
  },
  "keywords": [
    "electron",
    "file-manager",
    "openclaw"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.openclaw.files",
    "productName": "OpenClaw Files",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "main.js",
      "renderer.js",
      "styles.css",
      "README.md",
      "OPENCLAW_GATEWAY.md",
      ".env.example",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/backend/dist/OpenClawBackend",
        "to": "backend/OpenClawBackend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "mammoth": "^1.12.0",
    "xlsx": "^0.18.5"
  }
}
