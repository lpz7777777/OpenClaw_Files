# Anthropic API 密钥
# 可在 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=your_api_key_here

# OpenClaw Gateway WebSocket 配置
# 你的本地实例通常运行在 ws://127.0.0.1:18789
USE_GATEWAY=true
GATEWAY_URL=ws://127.0.0.1:18789
GATEWAY_TOKEN=openclaw-local-token
GATEWAY_PASSWORD=
GATEWAY_AGENT_ID=main
GATEWAY_USER=main
GATEWAY_SESSION_KEY=agent:main:main
GATEWAY_MODEL=openclaw
GATEWAY_CLIENT_ID=gateway-client
GATEWAY_CLIENT_MODE=backend
GATEWAY_SCOPES=operator.read,operator.write
GATEWAY_TIMEOUT=60
GATEWAY_STATE_DIR=.openclaw-state
GATEWAY_AUTO_APPROVE_LOCAL_PAIRING=true

# OpenClaw CLI 运行模式
# auto: 优先本机，其次 WSL
# native: 只使用 Windows 本机 openclaw
# wsl: 只使用 WSL 内的 openclaw
OPENCLAW_CLI_MODE=auto
# OPENCLAW_CLI_PATH=
# OPENCLAW_WSL_DISTRO=

# bdpan CLI 运行模式
# auto: 优先本机，其次 WSL
# native: 只使用 Windows 本机 bdpan
# wsl: 只使用 WSL 内的 bdpan
BDPAN_CLI_MODE=auto
# BDPAN_BIN=
# BDPAN_WSL_DISTRO=
